# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  TerapiSeansım — Railway Environment Variables
#  Railway Dashboard → Variables → Raw Editor'a yapıştırın
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ENV=production

# JWT — openssl rand -hex 64
JWT_SECRET=asdasdasdasdasdasdasdasdasdasdasdasd13123afsfa123ewasdasdfghfdhdhdfg
JWT_EXPIRES_IN=7d

# Veritabanı — Railway Volume /data'ya mount edilmeli
DB_PATH=/data/terapiseansim.db

# CORS — Frontend URL'iniz (* = herkese izin ver, test için)
# Güvenli üretim için: CORS_ORIGIN=https://www.seansim.com,https://seansim.com
CORS_ORIGIN=*

BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=120

# ── Anthropic AI ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Calendar OAuth2 ────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=https://terapiseansimbackend-production.up.railway.app/api/calendar/callback
FRONTEND_URL=https://terapi.seansim.com

# ── E-posta (Resend — resend.com, ücretsiz 3000/ay) ───────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=TerapiSeansım <info@seansim.com>
